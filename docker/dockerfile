# =============================================================================
# Dockerfile - multi-stage (slim) for MapsProveFiber
# =============================================================================
# Stage 1 (builder)        — compila wheels Python (inclui GDAL/PostGIS)
# Stage 2 (frontend-build) — build do frontend Vue 3 com Vite
# Stage 3 (runtime)        — imagem final de produção (sem Playwright, sem MySQL)
#
# Labels OCI para publicação no GHCR:
#   org.opencontainers.image.source = https://github.com/ORG/REPO
# =============================================================================

ARG PYTHON_VERSION=3.12

############################
# Stage 1: Python wheels
############################
FROM python:${PYTHON_VERSION}-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

# Build deps: compilação de extensões nativas (PostGIS, Pillow, psycopg)
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    python3-dev \
    libpq-dev \
    pkg-config \
    gdal-bin \
    libgdal-dev \
    libgeos-dev \
    proj-bin \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app/backend

COPY backend/requirements.txt ./requirements.txt

RUN pip install --upgrade pip wheel && \
    pip wheel --no-deps --wheel-dir=/wheels -r requirements.txt


############################
# Stage 2: Frontend build
############################
FROM node:20-slim AS frontend-builder

WORKDIR /app/frontend

COPY frontend/package*.json ./
RUN npm ci

RUN mkdir -p /app/backend/staticfiles/vue-spa/assets

COPY frontend/ ./
RUN npm run build

RUN ls -lah /app/backend/staticfiles/vue-spa/ && \
    ls -lah /app/backend/staticfiles/vue-spa/assets/


############################
# Stage 3: Runtime
############################
FROM python:${PYTHON_VERSION}-slim AS runtime

LABEL org.opencontainers.image.title="MapsProveFiber" \
      org.opencontainers.image.description="Fiber Optic Network Management Platform" \
      org.opencontainers.image.url="https://github.com/kaled182/provemaps_beta" \
      org.opencontainers.image.source="https://github.com/kaled182/provemaps_beta" \
      org.opencontainers.image.licenses="Proprietary"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONHASHSEED=random \
    PIP_NO_CACHE_DIR=1 \
    TZ=UTC \
    DJANGO_SETTINGS_MODULE=settings.prod \
    PYTHONPATH=/app/backend:/app \
    GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so \
    GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so \
    PROJ_LIB=/usr/share/proj \
    LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu

# Runtime deps: apenas bibliotecas necessárias para execução
# Sem: libmariadb3, Playwright/Chromium (removidos)
RUN apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    libpq5 \
    postgresql-client \
    ca-certificates \
    curl \
    netcat-openbsd \
    tzdata \
    gdal-bin \
    libgdal-dev \
    libgeos-dev \
    proj-bin \
    procps \
  && rm -rf /var/lib/apt/lists/* \
  && ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# Non-root user
ARG APP_USER=appuser
ARG APP_UID=1001
ARG APP_GID=1001
RUN groupadd -g ${APP_GID} ${APP_USER} && \
    useradd -m -u ${APP_UID} -g ${APP_GID} -s /bin/bash ${APP_USER}

WORKDIR /app/backend

# Instalar dependências a partir dos wheels compilados no Stage 1
COPY --from=builder /wheels /wheels
COPY backend/requirements.txt /app/backend/requirements.txt
RUN pip install --no-index --find-links=/wheels -r requirements.txt && \
    pip install --no-cache-dir gunicorn uvicorn celery && \
    rm -rf /wheels /root/.cache

# Código da aplicação
COPY backend/ /app/backend/
COPY scripts/ /app/scripts/

# Assets do frontend (compilados no Stage 2)
COPY --from=frontend-builder /app/backend/staticfiles/vue-spa/ /app/backend/staticfiles/vue-spa/

RUN ls -lah /app/backend/staticfiles/vue-spa/assets/ || echo "Frontend assets not found"

# Diretórios de runtime
RUN mkdir -p /app/backend/logs /app/backend/media /app/backend/staticfiles /app/backend/tmp && \
    chown -R ${APP_USER}:${APP_USER} /app && \
    chmod -R 755 /app

USER ${APP_USER}

EXPOSE 8000

# Comando definido no docker-compose (web/celery/beat)
