# =============================================================================
# MapsProveFiber - Production Environment Configuration
# =============================================================================
# 1. Copie este arquivo: cp .env.production.example .env.production
# 2. Preencha TODOS os valores marcados com <CHANGE_ME>
# 3. NUNCA commit .env.production no repositório
#
# Perfis disponíveis (COMPOSE_PROFILES):
#   minimal     → web + postgres + redis + celery + nginx  (padrão)
#   monitoring  → + prometheus + grafana
#   video       → + mediamtx + video-hls + video-transmuxer
#   whatsapp    → + whatsapp-qr
#   full        → todos os serviços
# =============================================================================

# =============================================================================
# OBRIGATÓRIAS — A aplicação não sobe sem estes valores
# =============================================================================

# Django secret key (mínimo 50 caracteres, gerada com: openssl rand -base64 50)
SECRET_KEY=<CHANGE_ME>

# Domínio público da aplicação (sem https://, sem barra final)
DOMAIN_NAME=app.example.com

# Hosts permitidos (separados por vírgula)
ALLOWED_HOSTS=app.example.com

# Origins confiáveis para CSRF (com https://)
CSRF_TRUSTED_ORIGINS=https://app.example.com

# Banco de dados PostgreSQL/PostGIS
DB_NAME=mapsprovefiber
DB_USER=mapsprovefiber
DB_PASSWORD=<CHANGE_ME>

# Senha do Redis (mínimo 16 caracteres, gerada com: openssl rand -base64 16)
REDIS_PASSWORD=<CHANGE_ME>

# =============================================================================
# PERFIL DE SERVIÇOS
# =============================================================================
# Escolha quais serviços subir. Valores possíveis: minimal, monitoring, video,
# whatsapp, full (ou combinações: "monitoring,whatsapp")
COMPOSE_PROFILES=minimal

# =============================================================================
# SSL (Let's Encrypt via Certbot)
# =============================================================================
# E-mail para notificações de renovação de certificado
CERTBOT_EMAIL=admin@example.com

# =============================================================================
# SEGURANÇA
# =============================================================================
DEBUG=false
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
SESSION_COOKIE_SAMESITE=Lax
USE_X_FORWARDED_HOST=true

# =============================================================================
# BANCO DE DADOS — valores avançados (opcionais)
# =============================================================================
DB_CONN_MAX_AGE=300
# DB_PORT=5432  # padrão

# =============================================================================
# INICIALIZAÇÃO
# =============================================================================
# true → roda migrations automaticamente ao subir
INIT_MIGRATE=true
# true → roda collectstatic automaticamente ao subir
INIT_COLLECTSTATIC=true
# true → cria superuser admin se não existir (usa ADMIN_USERNAME/ADMIN_PASSWORD)
INIT_ENSURE_SUPERUSER=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<CHANGE_ME>
ADMIN_EMAIL=admin@example.com
# true → popula dados iniciais (tarefas Celery, configurações base)
INIT_APP_DATA=true

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=<CHANGE_ME>
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@example.com

# =============================================================================
# INTEGRAÇÕES OPCIONAIS
# =============================================================================

# Zabbix (deixe em branco para modo offline)
ZABBIX_API_URL=
ZABBIX_API_KEY=
# ZABBIX_API_USER=
# ZABBIX_API_PASSWORD=

# Google Maps (para rotas de fibra)
GOOGLE_MAPS_API_KEY=

# Sentry (monitoramento de erros)
# SENTRY_DSN=https://your-key@sentry.io/project-id
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.05

# =============================================================================
# SERVIÇOS DE MÍDIA (perfil: video)
# =============================================================================
# VIDEO_WEBRTC_PUBLIC_BASE_URL=https://media.example.com
# VIDEO_HLS_BASE_URL=https://media.example.com

# =============================================================================
# WHATSAPP (perfil: whatsapp)
# =============================================================================
WHATSAPP_QR_SERVICE_URL=http://whatsapp-qr:3000

# =============================================================================
# MONITORAMENTO (perfil: monitoring)
# =============================================================================
# Grafana — altere a senha padrão!
GF_SECURITY_ADMIN_PASSWORD=<CHANGE_ME>

# =============================================================================
# BACKUP AUTOMÁTICO (opcional)
# =============================================================================
BACKUP_RETENTION_DAYS=30
# AWS_BACKUP_BUCKET=s3://meu-bucket/backups
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
LOG_FORMAT=json

# =============================================================================
# LIMITES DE UPLOAD
# =============================================================================
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# =============================================================================
# HEALTH CHECKS
# =============================================================================
HEALTHCHECK_STRICT=true
HEALTHCHECK_IGNORE_CACHE=false
HEALTHCHECK_DB_TIMEOUT=5
HEALTHCHECK_DISK_THRESHOLD_GB=2.0

# =============================================================================
# CELERY
# =============================================================================
CELERY_STATUS_TIMEOUT=6
CELERY_PING_TIMEOUT=2
CELERY_METRICS_ENABLED=true
CELERY_METRICS_UPDATE_INTERVAL=30
