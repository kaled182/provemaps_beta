    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.28.0",
    "jsdom": "^27.4.0",
    "pyright": "^1.1.407",
    "vitest": "^1.2.0",
    "vue-eslint-parser": "^9.4.3"
  },
  "jest": {
