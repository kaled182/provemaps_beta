SECRET_KEY="CHANGE_ME_SECRET_KEY"
FERNET_KEY=""
DEBUG="True"

# Database (configure DATABASE_URL or the fields below)
DATABASE_URL=""
DATABASE_ENGINE="django.db.backends.mysql"
DATABASE_NAME="mapspro_db"
DATABASE_USER="mapspro_user"
DATABASE_PASSWORD=""
DATABASE_HOST="127.0.0.1"
DATABASE_PORT="3306"
DATABASE_CHARSET="utf8mb4"

ZABBIX_API_URL="http://127.0.0.1:8080/api_jsonrpc.php"
ZABBIX_API_USER=""
ZABBIX_API_PASSWORD=""
ZABBIX_API_KEY=""

# Google Maps API Key (obrigatório para routes_builder/fiber-route-builder/)
# Obtenha em: https://console.cloud.google.com/google/maps-apis/credentials
# Docs: docs/GOOGLE_MAPS_API_SETUP.md
GOOGLE_MAPS_API_KEY=""

ALLOWED_HOSTS="localhost,127.0.0.1"
ENABLE_DIAGNOSTIC_ENDPOINTS="false"

REDIS_URL="redis://127.0.0.1:6379/0"
# Optional: e.g. redis://127.0.0.1:6379/1 for Channels
CHANNEL_LAYER_URL=""

# ─────────────────────────────────────────────────────────────────────────────
# Health Check Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Endpoints: /healthz (comprehensive), /ready (readiness), /live (liveness)

# Strict mode: if true, any failed check results in HTTP 503 (default: true)
HEALTHCHECK_STRICT="true"

# Ignore cache failures (useful in dev when Redis is unavailable)
HEALTHCHECK_IGNORE_CACHE="false"

# Database connection timeout in seconds (Unix/Linux only, default: 5)
HEALTHCHECK_DB_TIMEOUT="5"

# Minimum free disk space threshold in GB (default: 1.0)
HEALTHCHECK_DISK_THRESHOLD_GB="1.0"

# Enable/disable storage check (default: true)
HEALTHCHECK_STORAGE="true"

# Include system metrics (CPU, memory) in /healthz payload (default: false)
HEALTHCHECK_SYSTEM_METRICS="false"

# Debug mode: force logging even when healthy (default: false)
HEALTHCHECK_DEBUG="false"

# ─────────────────────────────────────────────────────────────────────────────
# Celery Status & Metrics Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Endpoint: /celery/status (worker health, queue stats)

# Timeout para coleta de estatísticas detalhadas em segundos (default: 3)
CELERY_STATUS_TIMEOUT="6"

# Timeout para ping leve do worker em segundos (default: 2)
CELERY_PING_TIMEOUT="2"

# Habilitar/desabilitar métricas Prometheus do Celery (default: true)
CELERY_METRICS_ENABLED="true"

# Intervalo de atualização periódica de métricas pelo beat em segundos (default: 30)
CELERY_METRICS_UPDATE_INTERVAL="30"

# ─────────────────────────────────────────────────────────────────────────────
# Zabbix Client Resilience Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Cliente Zabbix com retry, backoff, circuit breaker e métricas Prometheus

# Timeout para requisições ao Zabbix API em segundos (default: 15)
ZABBIX_REQUEST_TIMEOUT="15"

# Número máximo de tentativas de retry em caso de falha (default: 3)
ZABBIX_RETRY_MAX_ATTEMPTS="3"

# Fator de exponential backoff para retry (default: 2.0)
ZABBIX_RETRY_BACKOFF_FACTOR="2.0"

# Threshold de falhas consecutivas para abrir circuit breaker (default: 5)
ZABBIX_CIRCUIT_BREAKER_THRESHOLD="5"

# Timeout em segundos para tentar recuperar circuit breaker (default: 60)
ZABBIX_CIRCUIT_BREAKER_TIMEOUT="60"

# Tamanho máximo de batch de requisições (default: 10)
ZABBIX_BATCH_SIZE="10"

# ─────────────────────────────────────────────────────────────────────────────
# Cache SWR (Stale-While-Revalidate) Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Cache inteligente para dashboard com revalidação em background

# Habilitar/desabilitar cache SWR (default: true)
SWR_ENABLED="true"

# TTL de dados frescos em segundos (default: 300 = 5 min)
SWR_FRESH_TTL="300"

# TTL de dados stale em segundos (default: 1800 = 30 min)
SWR_STALE_TTL="1800"
