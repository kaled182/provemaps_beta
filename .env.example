SECRET_KEY="CHANGE_ME_SECRET_KEY"
FERNET_KEY=""
DEBUG="True"
PYTHONPATH="./backend"

# Database (configure DATABASE_URL or the fields below)
DATABASE_URL=""
DATABASE_ENGINE="django.db.backends.mysql"
DATABASE_NAME="mapspro_db"
DATABASE_USER="mapspro_user"
DATABASE_PASSWORD=""
DATABASE_HOST="127.0.0.1"
DATABASE_PORT="3306"
DATABASE_CHARSET="utf8mb4"

ZABBIX_API_URL="http://127.0.0.1:8080/api_jsonrpc.php"
ZABBIX_API_USER=""
ZABBIX_API_PASSWORD=""
ZABBIX_API_KEY=""

# Google Maps API Key (required for routes_builder/fiber-route-builder/)
# Get it at: https://console.cloud.google.com/google/maps-apis/credentials
# Docs: doc/reference/GOOGLE_MAPS_API_SETUP.md
GOOGLE_MAPS_API_KEY=""

ALLOWED_HOSTS="localhost,127.0.0.1"
ENABLE_DIAGNOSTIC_ENDPOINTS="false"

REDIS_URL="redis://127.0.0.1:6379/0"
# Optional: e.g. redis://127.0.0.1:6379/1 for Channels
CHANNEL_LAYER_URL=""

SERVICE_RESTART_COMMANDS="docker compose restart web; docker compose restart celery; docker compose restart beat"

# ─────────────────────────────────────────────────────────────────────────────
# Health Check Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Endpoints: /healthz (comprehensive), /ready (readiness), /live (liveness)

# Strict mode: if true, any failed check results in HTTP 503 (default: true)
HEALTHCHECK_STRICT="true"

# Ignore cache failures (useful in dev when Redis is unavailable)
HEALTHCHECK_IGNORE_CACHE="false"

# Database connection timeout in seconds (Unix/Linux only, default: 5)
HEALTHCHECK_DB_TIMEOUT="5"

# Minimum free disk space threshold in GB (default: 1.0)
HEALTHCHECK_DISK_THRESHOLD_GB="1.0"

# Enable/disable storage check (default: true)
HEALTHCHECK_STORAGE="true"

# Include system metrics (CPU, memory) in /healthz payload (default: false)
HEALTHCHECK_SYSTEM_METRICS="false"

# Debug mode: force logging even when healthy (default: false)
HEALTHCHECK_DEBUG="false"

# ─────────────────────────────────────────────────────────────────────────────
# Celery Status & Metrics Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Endpoint: /celery/status (worker health, queue stats)

# Timeout for detailed statistic collection in seconds (default: 3)
CELERY_STATUS_TIMEOUT="6"

# Timeout for lightweight worker ping in seconds (default: 2)
CELERY_PING_TIMEOUT="2"

# Enable/disable Celery Prometheus metrics (default: true)
CELERY_METRICS_ENABLED="true"

# Periodic metrics refresh interval (beat) in seconds (default: 30)
CELERY_METRICS_UPDATE_INTERVAL="30"

# Service account rotation
SERVICE_ACCOUNT_ROTATION_INTERVAL_SECONDS=3600
SERVICE_ACCOUNT_WEBHOOK_CONNECT_TIMEOUT=3
SERVICE_ACCOUNT_WEBHOOK_READ_TIMEOUT=5

# ─────────────────────────────────────────────────────────────────────────────
# WhatsApp QR Service
# ─────────────────────────────────────────────────────────────────────────────
WHATSAPP_QR_SERVICE_URL="http://whatsapp-qr:3000"

# ─────────────────────────────────────────────────────────────────────────────
# Zabbix Client Resilience Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Zabbix client with retry, backoff, circuit breaker, and Prometheus metrics

# Timeout for Zabbix API requests in seconds (default: 15)
ZABBIX_REQUEST_TIMEOUT="15"

# Maximum retry attempts on failure (default: 3)
ZABBIX_RETRY_MAX_ATTEMPTS="3"

# Exponential backoff factor for retries (default: 2.0)
ZABBIX_RETRY_BACKOFF_FACTOR="2.0"

# Consecutive failure threshold to open the circuit breaker (default: 5)
ZABBIX_CIRCUIT_BREAKER_THRESHOLD="5"

# Recovery timeout for the circuit breaker in seconds (default: 60)
ZABBIX_CIRCUIT_BREAKER_TIMEOUT="60"

# Maximum request batch size (default: 10)
ZABBIX_BATCH_SIZE="10"

# ─────────────────────────────────────────────────────────────────────────────
# Cache SWR (Stale-While-Revalidate) Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Smart dashboard cache with background revalidation

# Enable/disable SWR cache (default: true)
SWR_ENABLED="true"

# TTL of fresh data in seconds (default: 300 = 5 min)
SWR_FRESH_TTL="300"

# TTL of stale data in seconds (default: 1800 = 30 min)
SWR_STALE_TTL="1800"
