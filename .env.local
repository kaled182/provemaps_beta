# ====================================================
# 🛰️  PROVEMAPS — CONFIGURAÇÃO DE DESENVOLVIMENTO LOCAL
# ====================================================
# Para usar: renomeie para .env ou defina ENV_FILE_PATH=.env.local
# ====================================================

# ----------------------------------------------------
# 🔧 Django Core
# ----------------------------------------------------
SECRET_KEY=dev-local-secret-key-not-for-production-xyz789
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ----------------------------------------------------
# 🗄️ Banco de Dados (SQLite - sem necessidade de MySQL local)
# ----------------------------------------------------
# Deixando vazio usa SQLite automaticamente (db.sqlite3)
DATABASE_URL=
DATABASE_ENGINE=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_CHARSET=utf8mb4

# ----------------------------------------------------
# ⚙️ Cache / Redis (ignorado em dev - opcional)
# ----------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0

# ----------------------------------------------------
# 🗺️ Google Maps API (obrigatório para Fiber Route Builder)
# ----------------------------------------------------
# Obtenha gratuitamente em: https://console.cloud.google.com
# Veja: docs/GOOGLE_MAPS_API_SETUP.md para guia completo
GOOGLE_MAPS_API_KEY=
# Exemplo: GOOGLE_MAPS_API_KEY=AIzaSyC-dQd3sOmeExampleKey123456789
CHANNEL_LAYER_URL=

# ----------------------------------------------------
# 🚀 Health Checks (configuração relaxada para dev)
# ----------------------------------------------------
HEALTHCHECK_STRICT=false
HEALTHCHECK_IGNORE_CACHE=true
HEALTHCHECK_DB_TIMEOUT=5
HEALTHCHECK_DISK_THRESHOLD_GB=1.0
HEALTHCHECK_STORAGE=true
HEALTHCHECK_SYSTEM_METRICS=false
HEALTHCHECK_DEBUG=false

# ----------------------------------------------------
# 🎯 Zabbix API (opcional - deixe vazio para dev sem Zabbix)
# ----------------------------------------------------
ZABBIX_API_URL=
ZABBIX_API_USER=
ZABBIX_API_PASSWORD=
ZABBIX_API_KEY=
ZABBIX_READ_ONLY=True

# ----------------------------------------------------
# 🗺️ Google Maps (opcional - funciona sem)
# ----------------------------------------------------
GOOGLE_MAPS_API_KEY=

# ----------------------------------------------------
# 🔧 Features de desenvolvimento
# ----------------------------------------------------
ENABLE_DIAGNOSTIC_ENDPOINTS=false

# ----------------------------------------------------
# 🔐 Criptografia (será gerado automaticamente se vazio)
# ----------------------------------------------------
FERNET_KEY=

# ----------------------------------------------------
# 📝 Observações
# ----------------------------------------------------
# Este arquivo está configurado para rodar localmente SEM:
# - MySQL/MariaDB (usa SQLite)
# - Redis (health checks ignoram falhas)
# - Zabbix (opcional)
# 
# Para rodar:
# 1. Renomeie para .env (ou use: $env:ENV_FILE_PATH=".env.local")
# 2. python manage.py migrate
# 3. python manage.py createsuperuser
# 4. python manage.py runserver
